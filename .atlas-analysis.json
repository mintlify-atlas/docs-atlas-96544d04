  "keyFeatures": [
    "ISO 13528:2022 Algorithm A iterative robust mean and standard deviation via Winsorization",
    "Normalized IQR (nIQR) and scaled MAD (MADe) as robust scale estimators",
    "Four score types: z, z', zeta, and En for diverse proficiency testing scenarios",
    "Vectorized score evaluation for batch-processing participant results",
    "Homogeneity assessment with ANOVA-based between- and within-sample statistics",
    "Stability assessment comparing stability and homogeneity study means",
    "Expanded criteria incorporating uncertainty contributions per ISO 13528:2022",
    "Uncertainty budget components u_hom and u_stab for assigned value uncertainty"
  ],
  "publicApiSurface": [
    "calculate_niqr(x)",
    "calculate_mad_e(x)",
    "run_algorithm_a(values, ids, max_iter)",
    "calculate_z_score(x, x_pt, sigma_pt)",
    "calculate_z_prime_score(x, x_pt, sigma_pt, u_xpt)",
    "calculate_zeta_score(x, x_pt, u_x, u_xpt)",
    "calculate_en_score(x, x_pt, U_x, U_xpt)",
    "evaluate_z_score(z)",
    "evaluate_z_score_vec(z)",
    "evaluate_en_score(en)",
    "evaluate_en_score_vec(en)",
    "calculate_homogeneity_stats(sample_data)",
    "calculate_homogeneity_criterion(sigma_pt)",
    "calculate_homogeneity_criterion_expanded(sigma_pt, u_sigma_pt)",
    "evaluate_homogeneity(ss, c_criterion, c_expanded)",
    "calculate_stability_stats(stab_sample_data, hom_general_mean_homog, hom_stab_x_pt, hom_stab_sigma_pt)",
    "calculate_stability_criterion(sigma_pt)",
    "calculate_stability_criterion_expanded(c_criterion, u_hom_mean, u_stab_mean)",
    "evaluate_stability(diff_hom_stab, c_criterion, c_expanded)",
    "calculate_u_hom(ss)",
    "calculate_u_stab(diff_hom_stab, c_criterion)"
  ]
